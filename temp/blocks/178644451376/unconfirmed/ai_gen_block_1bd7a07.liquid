{% doc %}
  @prompt
    a grid of brand metaobjects shown as cards (brand image, name, and collection link), this showed up: "The metaobject definition required for this setting is not available", metaobject selection needs to be recursive (all entries are shown in grid)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-brand-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-brand-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-brand-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-brand-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_aspect_ratio }}%;
    background-color: {{ block.settings.image_background }};
    overflow: hidden;
  }

  .ai-brand-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-brand-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-brand-card__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-brand-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-brand-card__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-brand-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-brand-card__link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: 500;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .ai-brand-card__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-brand-card__link-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .ai-brand-card__link-{{ ai_gen_id }}:hover .ai-brand-card__link-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-brand-grid__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-brand-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-brand-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-brand-card__content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<brand-grid-{{ ai_gen_id }} class="ai-brand-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.metaobject_type != blank %}
    {% assign all_brands = shop.metaobjects[block.settings.metaobject_type].values %}
    
    {% if all_brands.size > 0 %}
      <div class="ai-brand-grid__container-{{ ai_gen_id }}">
        {% for brand in all_brands %}
          <div class="ai-brand-card-{{ ai_gen_id }}">
            <div class="ai-brand-card__image-wrapper-{{ ai_gen_id }}">
              {% if brand[block.settings.image_field] %}
                <img
                  src="{{ brand[block.settings.image_field] | image_url: width: 600 }}"
                  alt="{{ brand[block.settings.image_field].alt | default: brand[block.settings.name_field] | escape }}"
                  class="ai-brand-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-brand-card__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-brand-card__content-{{ ai_gen_id }}">
              {% if brand[block.settings.name_field] %}
                <h3 class="ai-brand-card__name-{{ ai_gen_id }}">{{ brand[block.settings.name_field] }}</h3>
              {% endif %}

              {% if brand[block.settings.description_field] and block.settings.show_description %}
                <p class="ai-brand-card__description-{{ ai_gen_id }}">{{ brand[block.settings.description_field] }}</p>
              {% endif %}

              {% if brand[block.settings.collection_field] %}
                <a href="{{ brand[block.settings.collection_field].url }}" class="ai-brand-card__link-{{ ai_gen_id }}">
                  {{ block.settings.link_text }}
                  <svg class="ai-brand-card__link-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-brand-grid__empty-{{ ai_gen_id }}">
        No brand entries found. Create brand metaobjects to display them here.
      </div>
    {% endif %}
  {% else %}
    <div class="ai-brand-grid__empty-{{ ai_gen_id }}">
      Next, enter your metaobject type below (e.g., "brand")
    </div>
  {% endif %}
</brand-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('brand-grid-{{ ai_gen_id }}', BrandGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Brand grid",
  "settings": [
    {
      "type": "header",
      "content": "Metaobject configuration"
    },
    {
      "type": "paragraph",
      "content": "Enter the metaobject type and field names to display all entries automatically"
    },
    {
      "type": "text",
      "id": "metaobject_type",
      "label": "Metaobject type",
      "info": "Enter the metaobject type handle (e.g., brand)"
    },
    {
      "type": "text",
      "id": "name_field",
      "label": "Name field",
      "default": "name",
      "info": "Field handle for the brand name"
    },
    {
      "type": "text",
      "id": "image_field",
      "label": "Image field",
      "default": "image",
      "info": "Field handle for the brand image"
    },
    {
      "type": "text",
      "id": "description_field",
      "label": "Description field",
      "default": "description",
      "info": "Field handle for the brand description"
    },
    {
      "type": "text",
      "id": "collection_field",
      "label": "Collection field",
      "default": "collection",
      "info": "Field handle for the collection reference"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "View collection"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 75,
      "info": "100% = square, 75% = landscape, 133% = portrait"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Background",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "brand_name_size",
      "label": "Brand name size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#141414"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "link_size",
      "label": "Link size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#e9b217"
    }
  ],
  "presets": [
    {
      "name": "Brand grid"
    }
  ]
}
{% endschema %}
