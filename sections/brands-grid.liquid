{% assign bg_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .brands-grid-{{ bg_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .brands-grid__container-{{ bg_id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  .brands-grid__card-{{ bg_id }} {
    background-color: {{ section.settings.card_background }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .brands-grid__card-{{ bg_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .brands-grid__image-wrapper-{{ bg_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ section.settings.image_aspect_ratio }}%;
    background-color: {{ section.settings.image_background }};
    overflow: hidden;
  }

  .brands-grid__image-{{ bg_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
  }

  .brands-grid__placeholder-{{ bg_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .brands-grid__placeholder-{{ bg_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .brands-grid__content-{{ bg_id }} {
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .brands-grid__name-{{ bg_id }} {
    font-size: {{ section.settings.brand_name_size }}px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .brands-grid__link-{{ bg_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: {{ section.settings.link_color }};
    text-decoration: none;
    font-size: {{ section.settings.link_size }}px;
    font-weight: 500;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .brands-grid__link-{{ bg_id }}:hover {
    color: {{ section.settings.link_hover_color }};
  }

  .brands-grid__link-arrow-{{ bg_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .brands-grid__link-{{ bg_id }}:hover .brands-grid__link-arrow-{{ bg_id }} {
    transform: translateX(4px);
  }

  .brands-grid__empty-{{ bg_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  .brands-grid__sort-bar-{{ bg_id }} {
    display: flex;
    justify-content: flex-end;
    padding-bottom: var(--padding-xs, 8px);
  }

  @media screen and (max-width: 989px) {
    .brands-grid__container-{{ bg_id }} {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .brands-grid__container-{{ bg_id }} {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.grid_gap | times: 0.75 }}px;
    }

    .brands-grid__content-{{ bg_id }} {
      padding: {{ section.settings.card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--page-width color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="custom-section-content">
    <div class="spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
      <div class="brands-grid-{{ bg_id }}">
        {% paginate shop.metaobjects["marques"].values by 250 %}
          {% assign all_brands = shop.metaobjects["marques"].values %}
          {% if all_brands.size > 0 %}
            {% if section.settings.enable_sorting %}
              {% assign default_sort = section.settings.default_sort_order | default: 'default' %}
              {% case default_sort %}
                {% when 'name-asc' %}{% assign default_sort_name = 'A → Z' %}
                {% when 'name-desc' %}{% assign default_sort_name = 'Z → A' %}
                {% else %}{% assign default_sort_name = 'Par défaut' %}
              {% endcase %}
              <div class="brands-grid__sort-bar-{{ bg_id }}">
                <details class="facets__panel sorting-filter" id="BrandsSort-{{ bg_id }}" data-default-sort="{{ default_sort }}">
                  <summary class="facets__summary">
                    <span class="facets__label">Trier par</span>
                    <span class="facets__status h6">{{ default_sort_name }}</span>
                    <span class="svg-wrapper icon-caret icon-animated">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                  </summary>
                  <div class="sorting-filter__options color-{{ settings.popover_color_scheme }}">
                    <div class="sorting-filter__options-inner">
                      <label>
                        <div class="sorting-filter__option" role="option" aria-selected="{{ default_sort == 'default' }}" tabindex="{% if default_sort == 'default' %}0{% else %}-1{% endif %}">
                          <input type="radio" name="brands_sort_{{ bg_id }}" value="default" class="sorting-filter__input" data-option-name="Par défaut" {% if default_sort == 'default' %}checked{% endif %} aria-hidden="true">
                          <span class="svg-wrapper icon-checkmark sorting-filter__checkmark">{{ 'icon-checkmark.svg' | inline_asset_content }}</span>
                          <span class="sorting-filter__label">Par défaut</span>
                        </div>
                      </label>
                      <label>
                        <div class="sorting-filter__option" role="option" aria-selected="{{ default_sort == 'name-asc' }}" tabindex="{% if default_sort == 'name-asc' %}0{% else %}-1{% endif %}">
                          <input type="radio" name="brands_sort_{{ bg_id }}" value="name-asc" class="sorting-filter__input" data-option-name="A → Z" {% if default_sort == 'name-asc' %}checked{% endif %} aria-hidden="true">
                          <span class="svg-wrapper icon-checkmark sorting-filter__checkmark">{{ 'icon-checkmark.svg' | inline_asset_content }}</span>
                          <span class="sorting-filter__label">A → Z</span>
                        </div>
                      </label>
                      <label>
                        <div class="sorting-filter__option" role="option" aria-selected="{{ default_sort == 'name-desc' }}" tabindex="{% if default_sort == 'name-desc' %}0{% else %}-1{% endif %}">
                          <input type="radio" name="brands_sort_{{ bg_id }}" value="name-desc" class="sorting-filter__input" data-option-name="Z → A" {% if default_sort == 'name-desc' %}checked{% endif %} aria-hidden="true">
                          <span class="svg-wrapper icon-checkmark sorting-filter__checkmark">{{ 'icon-checkmark.svg' | inline_asset_content }}</span>
                          <span class="sorting-filter__label">Z → A</span>
                        </div>
                      </label>
                    </div>
                  </div>
                </details>
              </div>
            {% endif %}
            <div class="brands-grid__container-{{ bg_id }}">
              {% for brand in all_brands %}
                <a
                  href="{{ brand[section.settings.collection_field].value }}"
                  class="brands-grid__card-{{ bg_id }}"
                  data-sort-name="{{ brand[section.settings.name_field].value | downcase }}"
                  data-original-index="{{ forloop.index0 }}"
                >
                  <div class="brands-grid__image-wrapper-{{ bg_id }}">
                    {% if brand[section.settings.image_field].value %}
                      <img
                        src="{{ brand[section.settings.image_field].value | image_url: width: 600 }}"
                        alt="{{ brand[section.settings.image_field].value.alt | default: brand[section.settings.name_field].value | escape }}"
                        class="brands-grid__image-{{ bg_id }}"
                        loading="lazy"
                        width="600"
                        height="{{ 600 | times: section.settings.image_aspect_ratio | divided_by: 100 }}"
                      >
                    {% else %}
                      <div class="brands-grid__placeholder-{{ bg_id }}">
                        {{ 'image' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="brands-grid__content-{{ bg_id }}">
                    {% if brand[section.settings.name_field].value %}
                      <h3 class="brands-grid__name-{{ bg_id }}">{{ brand[section.settings.name_field].value }}</h3>
                    {% endif %}

                    {% if brand[section.settings.collection_field].value %}
                      <span class="brands-grid__link-{{ bg_id }}">
                        {{ section.settings.link_text }}
                        <svg class="brands-grid__link-arrow-{{ bg_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                      </span>
                    {% endif %}
                  </div>
                </a>
              {% endfor %}
            </div>
          {% else %}
            <div class="brands-grid__empty-{{ bg_id }}">
              No brand entries found.
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var details = document.getElementById('BrandsSort-{{ bg_id }}');
  var container = document.querySelector('.brands-grid__container-{{ bg_id }}');
  if (!container || !details) return;
  var cards = Array.from(container.children);

  function sortCards(sort) {
    var sorted = cards.slice().sort(function(a, b) {
      if (sort === 'name-asc') return a.dataset.sortName.localeCompare(b.dataset.sortName, 'fr');
      if (sort === 'name-desc') return b.dataset.sortName.localeCompare(a.dataset.sortName, 'fr');
      return parseInt(a.dataset.originalIndex) - parseInt(b.dataset.originalIndex);
    });
    sorted.forEach(function(card) { container.appendChild(card); });
  }

  var defaultSort = details.dataset.defaultSort;
  if (defaultSort && defaultSort !== 'default') sortCards(defaultSort);

  details.querySelectorAll('.sorting-filter__input').forEach(function(input) {
    input.addEventListener('change', function() {
      var status = details.querySelector('.facets__status');
      if (status) status.textContent = this.dataset.optionName;

      details.querySelectorAll('.sorting-filter__option').forEach(function(opt) {
        opt.setAttribute('aria-selected', 'false');
        opt.setAttribute('tabindex', '-1');
      });
      var opt = this.closest('.sorting-filter__option');
      opt.setAttribute('aria-selected', 'true');
      opt.setAttribute('tabindex', '0');

      sortCards(this.value);
      details.removeAttribute('open');
    });
  });

  document.addEventListener('click', function(e) {
    if (!details.contains(e.target)) details.removeAttribute('open');
  });
})();
</script>

{% schema %}
{
  "name": "Brands grid",
  "settings": [
    {
      "type": "header",
      "content": "Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Show sort controls",
      "default": true
    },
    {
      "type": "select",
      "id": "default_sort_order",
      "label": "Default sort order",
      "options": [
        { "value": "default", "label": "Par défaut" },
        { "value": "name-asc", "label": "A → Z" },
        { "value": "name-desc", "label": "Z → A" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Fields"
    },
    {
      "type": "text",
      "id": "name_field",
      "label": "Name field",
      "default": "nom"
    },
    {
      "type": "text",
      "id": "image_field",
      "label": "Image field",
      "default": "logo"
    },
    {
      "type": "text",
      "id": "collection_field",
      "label": "Collection URL field",
      "default": "collection_url"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Voir les produits"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image background",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "brand_name_size",
      "label": "Brand name size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#141414"
    },
    {
      "type": "range",
      "id": "link_size",
      "label": "Link size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#e9b217"
    }
  ]
}
{% endschema %}
