{%- doc -%}
  Fixatech Breadcrumbs Section
  Renders a breadcrumb navigation bar based on the store's menu hierarchy.
  Displays on product and collection pages.

  @example
  Add this section to templates/product.json or templates/collection.json
{%- enddoc -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="fixatech-breadcrumbs-section section section--page-width spacing-style color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --breadcrumbs-font-size: {{ section.settings.font_size }};
    --breadcrumbs-text-case: {{ section.settings.text_case }};
    --breadcrumbs-font-weight: {{ section.settings.font_weight }};
  "
>
  {%- liquid
    assign menu_handle = section.settings.menu | default: 'main-menu'
  -%}
  {% render 'fixatech-breadcrumbs-nav', menu_handle: menu_handle, collection: collection, product: product %}
</div>

{% stylesheet %}
  .fixatech-breadcrumbs-section {
    width: 100%;
  }

  .fixatech-breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
    font-size: var(--breadcrumbs-font-size, 0.8125rem);
    line-height: 1.4;
    text-transform: var(--breadcrumbs-text-case, none);
    font-weight: var(--breadcrumbs-font-weight, 400);
  }

  .fixatech-breadcrumbs__item {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .fixatech-breadcrumbs__link {
    color: var(--color-foreground);
    opacity: 0.55;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .fixatech-breadcrumbs__link:hover {
    opacity: 0.85;
    text-decoration: underline;
  }

  .fixatech-breadcrumbs__separator {
    display: inline-block;
    margin-inline: 0.5em;
    color: var(--color-foreground);
    opacity: 0.4;
    font-size: 1em;
  }

  .fixatech-breadcrumbs__item--current {
    color: var(--color-foreground);
    opacity: 0.85;
    font-weight: calc(var(--breadcrumbs-font-weight, 400) + 100);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Select the menu to build breadcrumbs from."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        {
          "value": "0.6875rem",
          "label": "11px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.8125rem",
          "label": "13px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        }
      ],
      "default": "0.8125rem"
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "settings": {
        "menu": "main-menu",
        "font_size": "0.8125rem",
        "text_case": "none",
        "font_weight": "400",
        "color_scheme": "scheme-3",
        "padding-block-start": 16,
        "padding-block-end": 0
      }
    }
  ],
  "enabled_on": {
    "templates": ["product", "collection"]
  }
}
{% endschema %}
