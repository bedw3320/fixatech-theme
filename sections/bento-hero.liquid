{%- liquid
  assign cell_a_image         = section.settings.cell_a_image
  assign cell_a_heading       = section.settings.cell_a_heading
  assign cell_a_text          = section.settings.cell_a_text
  assign cell_b_image         = section.settings.cell_b_image
  assign cell_c_image         = section.settings.cell_c_image
  assign cell_c_heading       = section.settings.cell_c_heading
  assign cell_c_subtext       = section.settings.cell_c_subtext
  assign cell_c_product_image = section.settings.cell_c_product_image
  assign cell_c_price         = section.settings.cell_c_price
  assign cell_d_image         = section.settings.cell_d_image
  assign cell_d_cta_text      = section.settings.cell_d_cta_text
  assign cell_d_cta_link      = section.settings.cell_d_cta_link
-%}

{%- comment -%}
  ── Cell markup captured once, reused by both layouts ─────────────────
  Each cell gets a `bento-hero__cell--hide-mobile` modifier when its
  "Show in mobile" setting is off; the modifier is honored only inside
  the ≤767px media query, so desktop/tablet are never affected.
{%- endcomment -%}

{%- capture cell_a_html -%}
  <div class="bento-hero__cell bento-hero__cell-a{% if cell_a_image != blank %} bento-hero__cell-a--image{% endif %}{% unless section.settings.cell_a_show_mobile %} bento-hero__cell--hide-mobile{% endunless %}">
    {%- if cell_a_image != blank -%}
      {{
        cell_a_image
        | image_url: width: 800
        | image_tag:
          class: 'bento-hero__fill-img',
          loading: 'lazy',
          widths: '400, 800',
          sizes: '(max-width: 749px) 100vw, 33vw',
          alt: cell_a_image.alt | default: ''
      }}
    {%- else -%}
      <div class="bento-hero__cell-a-content">
        {%- if cell_a_heading != blank -%}
          <h2 class="bento-hero__cell-a-heading">{{ cell_a_heading }}</h2>
        {%- endif -%}
        {%- if cell_a_text != blank -%}
          <p class="bento-hero__cell-a-text">{{ cell_a_text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- capture cell_b_html -%}
  <div class="bento-hero__cell bento-hero__cell-b{% unless section.settings.cell_b_show_mobile %} bento-hero__cell--hide-mobile{% endunless %}">
    {%- if cell_b_image != blank -%}
      {{
        cell_b_image
        | image_url: width: 800
        | image_tag:
          class: 'bento-hero__fill-img',
          loading: 'lazy',
          widths: '400, 800',
          sizes: '(max-width: 749px) 100vw, 33vw',
          alt: cell_b_image.alt | default: ''
      }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'bento-hero__placeholder' }}
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- capture cell_c_html -%}
  <div class="bento-hero__cell bento-hero__cell-c{% if cell_c_image != blank %} bento-hero__cell-c--image{% endif %}{% unless section.settings.cell_c_show_mobile %} bento-hero__cell--hide-mobile{% endunless %}">
    {%- if cell_c_image != blank -%}
      {{
        cell_c_image
        | image_url: width: 800
        | image_tag:
          class: 'bento-hero__fill-img',
          loading: 'lazy',
          widths: '400, 800',
          sizes: '(max-width: 749px) 100vw, 33vw',
          alt: cell_c_image.alt | default: ''
      }}
    {%- else -%}
      <div class="bento-hero__cell-c-text">
        {%- if cell_c_heading != blank -%}
          <h3 class="bento-hero__cell-c-heading">{{ cell_c_heading }}</h3>
        {%- endif -%}
        {%- if cell_c_subtext != blank -%}
          <p class="bento-hero__cell-c-subtext">{{ cell_c_subtext }}</p>
        {%- endif -%}
      </div>

      <div class="bento-hero__cell-c-product">
        {%- if cell_c_product_image != blank -%}
          {{
            cell_c_product_image
            | image_url: width: 600
            | image_tag:
              class: 'bento-hero__cell-c-product-img',
              loading: 'lazy',
              widths: '300, 600',
              sizes: '(max-width: 749px) 80vw, 25vw',
              alt: cell_c_product_image.alt | default: ''
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'bento-hero__placeholder' }}
        {%- endif -%}
      </div>

      {%- if cell_c_price != blank -%}
        <div class="bento-hero__price-badge">{{ cell_c_price }}</div>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.cell_c_link != blank -%}
      <a href="{{ section.settings.cell_c_link }}" class="bento-hero__cell-overlay-link" aria-label="{{ cell_c_heading | escape }}"></a>
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- capture cell_d_html -%}
  <div class="bento-hero__cell bento-hero__cell-d{% unless section.settings.cell_d_show_mobile %} bento-hero__cell--hide-mobile{% endunless %}">
    {%- if cell_d_image != blank -%}
      {{
        cell_d_image
        | image_url: width: 1200
        | image_tag:
          class: 'bento-hero__fill-img',
          loading: 'lazy',
          widths: '600, 900, 1200',
          sizes: '(max-width: 749px) 100vw, 66vw',
          alt: cell_d_image.alt | default: ''
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'bento-hero__placeholder' }}
    {%- endif -%}

    <div class="bento-hero__cell-d-overlay" aria-hidden="true"></div>

    {%- if cell_d_cta_text != blank -%}
      <a
        href="{{ cell_d_cta_link | default: '#' }}"
        class="bento-hero__cta {{ section.settings.cta_style }}"
        {% if cell_d_cta_link == blank %}aria-disabled="true"{% endif %}
      >
        {{- cell_d_cta_text -}}
        {%- liquid
          assign show_arrow = false
          if section.settings.cta_style == 'button-secondary'
            assign show_arrow = settings.secondary_button_show_arrow
          else
            assign show_arrow = settings.primary_button_show_arrow
          endif
        -%}
        {%- if show_arrow -%}
          <span class="svg-wrapper button-arrow" aria-hidden="true">
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          </span>
        {%- endif -%}
      </a>
    {%- endif -%}
    {%- if cell_d_cta_link != blank -%}
      <a href="{{ cell_d_cta_link }}" class="bento-hero__cell-overlay-link" aria-hidden="true" tabindex="-1"></a>
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- comment -%}
  ── Build the mobile carousel order ───────────────────────────────────
  Each cell exposes a "Mobile order" position (1-4). We zero-pad and
  prefix the cell key so a plain string sort yields the chosen sequence;
  ties fall back to the key letter for a stable result.
{%- endcomment -%}
{%- liquid
  assign cell_keys = 'a,b,c,d' | split: ','
  assign sortable = ''
  for key in cell_keys
    assign order_id = 'cell_' | append: key | append: '_mobile_order'
    assign order_val = section.settings[order_id] | default: 9
    assign entry = order_val | append: '_' | append: key
    if forloop.first
      assign sortable = entry
    else
      assign sortable = sortable | append: ',' | append: entry
    endif
  endfor
  assign sorted_cells = sortable | split: ',' | sort
-%}

{% style %}
  .bento-hero--{{ section.id }} {
    {% render 'spacing-style', settings: section.settings %}
    --cell-a-bg:    {{ section.settings.cell_a_bg_color }};
    --cell-a-color: {{ section.settings.cell_a_text_color }};
    --cell-c-bg:    {{ section.settings.cell_c_bg_color }};
    --cell-c-color: {{ section.settings.cell_c_text_color }};
  }
  .bento-hero--{{ section.id }} .bento-hero__grid {
    --bento-col-c: {{ section.settings.cell_c_width_pct }}%;
    --bento-row-d: {{ section.settings.cell_d_height_pct }}%;
    {% if section.settings.section_height == 'auto' %}
      aspect-ratio: 16 / 7;
    {% elsif section.settings.section_height == 'custom' %}
      aspect-ratio: auto;
      height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      aspect-ratio: auto;
      height: 100svh;
    {% else %}
      aspect-ratio: auto;
      height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  }
  {% if section.settings.image_hover_zoom %}
    .bento-hero--{{ section.id }} .bento-hero__cell .bento-hero__fill-img,
    .bento-hero--{{ section.id }} .bento-hero__cell-c .bento-hero__cell-c-product-img {
      transition: transform var(--hover-transition-duration) var(--hover-transition-timing);
    }
    .bento-hero--{{ section.id }} .bento-hero__cell:hover .bento-hero__fill-img,
    .bento-hero--{{ section.id }} .bento-hero__cell-c:hover .bento-hero__cell-c-product-img {
      transform: scale(var(--hover-subtle-zoom-amount));
    }
  {% endif %}
{% endstyle %}

<div class="section section--{{ section.settings.section_width }} spacing-style bento-hero bento-hero--{{ section.id }}">
  <div>
    {%- if section.settings.carousel_on_mobile -%}

      {%- comment -%}
        ── Mobile carousel layout (carousel_on_mobile = true) ──────────────
        On mobile: cells are scroll-snap slides inside a track wrapper,
        rendered in the merchant-defined "Mobile order".
        On desktop/tablet: the track uses display:contents, making the
        cells participate as direct grid children, preserving the original
        grid-column/grid-row assignments regardless of DOM order.
      {%- endcomment -%}

      <div class="bento-hero__grid bento-hero__grid--carousel-mobile">

        {%- comment -%} Carousel track: cells ordered by "Mobile order" {%- endcomment -%}
        <div class="bento-hero__carousel-track" id="bento-track-{{ section.id }}">
          {%- for item in sorted_cells -%}
            {%- assign cell_key = item | split: '_' | last -%}
            {%- case cell_key -%}
              {%- when 'a' -%}{{ cell_a_html }}
              {%- when 'b' -%}{{ cell_b_html }}
              {%- when 'c' -%}{{ cell_c_html }}
              {%- when 'd' -%}{{ cell_d_html }}
            {%- endcase -%}
          {%- endfor -%}
        </div>{%- comment -%} /bento-hero__carousel-track {%- endcomment -%}

        {%- comment -%} Navigation arrows — visible on mobile only via CSS {%- endcomment -%}
        <button
          class="bento-hero__arrow bento-hero__arrow--prev"
          data-bento-prev="{{ section.id }}"
          aria-label="Précédent"
          disabled
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button
          class="bento-hero__arrow bento-hero__arrow--next"
          data-bento-next="{{ section.id }}"
          aria-label="Suivant"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

      </div>

    {%- else -%}

      {%- comment -%}
        ── Non-carousel layout (carousel_on_mobile = false) ────────────────
        bento-hero__secondary wrapper (display:contents) keeps A and B as
        direct grid children on all breakpoints.
      {%- endcomment -%}

      <div class="bento-hero__grid">

        <div class="bento-hero__secondary">
          {{ cell_a_html }}
          {{ cell_b_html }}
        </div>{%- comment -%} /bento-hero__secondary {%- endcomment -%}

        {{ cell_c_html }}
        {{ cell_d_html }}

      </div>

    {%- endif -%}
  </div>
</div>

{% stylesheet %}
/* Isolate the section's stacking context so internal z-indexes (notably the
   mobile carousel arrows at z-index:10) cannot paint above the sticky header
   layer (--layer-sticky: 8) and bleed over the open mobile menu drawer. */
.bento-hero {
  isolation: isolate;
}

.bento-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr var(--bento-col-c, 35%);
  grid-template-rows: 1fr var(--bento-row-d, 50%);
  gap: 8px;
}

/* ── Shared cell styles ─────────────────────────────────────── */
.bento-hero__cell {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
}

/* Shared full-cover image (used in A, B, C image mode, D) */
.bento-hero__fill-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Cell A — Text card (default) or image ──────────────────── */
.bento-hero__cell-a {
  grid-column: 1;
  grid-row: 1;
  background-color: var(--cell-a-bg, #141414);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 30px;
}

.bento-hero__cell-a--image {
  padding: 0;
}

.bento-hero__cell-a-content {
  text-align: center;
  color: var(--cell-a-color, #fff);
}

.bento-hero__cell-a-heading {
  font-size: 32px;
  margin: 0 0 12px;
  color: var(--cell-a-color, #fff);
}

.bento-hero__cell-a-text {
  font-size: 16px;
  margin: 0;
  color: var(--cell-a-color, #fff);
}

/* ── Cell B — Photo ─────────────────────────────────────────── */
.bento-hero__cell-b {
  grid-column: 2;
  grid-row: 1;
}

/* ── Cell C — Promo panel (default) or image ────────────────── */
.bento-hero__cell-c {
  grid-column: 3;
  grid-row: 1 / span 2;
  background-color: var(--cell-c-bg, #ffc600);
  display: flex;
  flex-direction: column;
  padding: 0;
}

.bento-hero__cell-c--image {
  padding: 0;
}

.bento-hero__cell-c-text {
  position: absolute;
  top: 24px;
  left: 20px;
  right: 20px;
  z-index: 1;
  color: var(--cell-c-color, #141414);
}

.bento-hero__cell-c-heading {
  font-size: 28px;
  margin: 0 0 12px;
  color: var(--cell-c-color, #141414);
}

.bento-hero__cell-c-subtext {
  font-size: 14px;
  margin: 0;
  color: var(--cell-c-color, #141414);
}

.bento-hero__cell-c-product {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
}

.bento-hero__cell-c-product-img {
  max-width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.bento-hero__price-badge {
  position: absolute;
  bottom: 30px;
  right: 30px;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background-color: #141414;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: #ffc600;
}

/* ── Cell D — Wide photo + CTA ──────────────────────────────── */
.bento-hero__cell-d {
  grid-column: 1 / span 2;
  grid-row: 2;
}

.bento-hero__cell-d-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  pointer-events: none;
}

/* ── CTA button — positioning only; visual styles from theme ── */
.bento-hero__cta {
  position: absolute;
  bottom: 30px;
  left: 30px;
  z-index: 2;
}

.bento-hero__cell-overlay-link {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.bento-hero__cell-overlay-link:focus-visible {
  outline: 2px solid currentColor;
  outline-offset: -3px;
}

/* ── Placeholder SVGs ───────────────────────────────────────── */
.bento-hero__placeholder {
  width: 100%;
  height: 100%;
  display: block;
  fill: #343434;
}

/*
  ── Secondary wrapper (A + B, non-carousel mode) ─────────────
  display:contents on all breakpoints: the wrapper is invisible
  to the grid algorithm — A and B act as direct grid children.
*/
.bento-hero__secondary {
  display: contents;
}

/*
  ── Carousel track (carousel_on_mobile = true) ───────────────
  Desktop/tablet: display:contents makes the track invisible to
  the grid — the cells each land on their grid-column/grid-row as
  if the track element does not exist.
*/
.bento-hero__carousel-track {
  display: contents;
}

/*
  ── Arrow buttons — hidden on desktop, shown on mobile ───────
  position:absolute is relative to .bento-hero__grid--carousel-mobile
  which gets position:relative on mobile (see below).
*/
.bento-hero__arrow {
  display: none;
}

/* ── Tablet (≤ 989px) ───────────────────────────────────────── */
@media screen and (max-width: 989px) {
  .bento-hero__grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    /* Override the inline style-block height/aspect-ratio so stacked cells aren't clipped */
    aspect-ratio: auto !important;
    height: auto !important;
  }

  /* Figma tablet — C on top full-width, A+B side by side, D hidden */
  .bento-hero__cell-c { grid-column: 1 / -1; grid-row: 1; min-height: 300px; }
  .bento-hero__cell-a { grid-column: 1; grid-row: 2; min-height: 150px; }
  .bento-hero__cell-b { grid-column: 2; grid-row: 2; min-height: 150px; }
  .bento-hero__cell-d { display: none; }
}

/* ── Mobile (≤ 767px) ───────────────────────────────────────── */
@media screen and (max-width: 767px) {

  /* ── Non-carousel mode: C full-width row 1, A+B side-by-side row 2 ── */
  .bento-hero__grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    height: auto !important;
    aspect-ratio: auto !important;
  }

  .bento-hero__cell-c { grid-column: 1 / -1; grid-row: 1; min-height: 272px; padding: 24px 16px; }
  .bento-hero__cell-c--image { padding: 0; }
  .bento-hero__cell-c-heading { font-size: 20px; }

  .bento-hero__cell-a { grid-column: 1; grid-row: 2; min-height: 120px; padding: 20px 16px; }
  .bento-hero__cell-a--image { padding: 0; }
  .bento-hero__cell-a-heading { font-size: 18px; }

  .bento-hero__cell-b { grid-column: 2; grid-row: 2; min-height: 120px; }

  .bento-hero__cell-d { display: none; }

  /*
    ── Show in mobile = off ─────────────────────────────────────
    Hides a cell on mobile only (both carousel and stacked layouts).
    !important beats the carousel cell-d display:block override below.
  */
  .bento-hero__cell--hide-mobile { display: none !important; }

  .bento-hero__price-badge {
    width: 56px;
    height: 56px;
    font-size: 13px;
    bottom: 16px;
    right: 16px;
  }

  /* ── Carousel mode (carousel_on_mobile = true) ──────────────
     .bento-hero__grid--carousel-mobile collapses to a single
     column with the track as a horizontal scroll container.
     display:contents on the track is overridden to display:flex.
     All four cells (C, A, B, D) become flex slides.
  */
  .bento-hero__grid--carousel-mobile {
    /* Single-column grid: track fills row 1, D (hidden) in row 2 */
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    position: relative;  /* anchor for absolute-positioned arrows */
    overflow: hidden;
    height: auto !important;
    aspect-ratio: auto !important;
  }

  /* Track: override display:contents → becomes the scroll container */
  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track {
    display: flex;
    grid-column: 1 / -1;
    grid-row: 1;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 8px;
  }

  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* Each cell inside the track becomes a scroll-snap slide */
  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell {
    /* Clear all grid placement — not grid children in carousel mode */
    grid-column: unset !important;
    grid-row: unset !important;
    /* Slide width: 85vw shows a peek of the next slide */
    flex: 0 0 85vw;
    min-width: 0;
    min-height: 240px;
    scroll-snap-align: start;
    height: auto;
  }

  /* Restore cell-specific padding overrides stripped by the rule above */
  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell-c {
    padding: 24px 16px;
  }

  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell-c--image {
    padding: 0;
  }

  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell-a {
    padding: 20px 16px;
  }

  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell-a--image {
    padding: 0;
  }

  /* Cell D: override the global mobile display:none when inside the carousel track */
  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track > .bento-hero__cell-d {
    display: block;
    padding: 0;
  }

  /* Arrow buttons — shown on mobile only */
  .bento-hero__arrow {
    display: flex;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    border: none;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s ease;
  }

  .bento-hero__arrow:hover {
    background: rgba(0, 0, 0, 0.8);
  }

  .bento-hero__arrow:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .bento-hero__arrow:focus-visible {
    outline: 2px solid #FFC600;
    outline-offset: 2px;
  }

  .bento-hero__arrow--prev {
    left: 8px;
  }

  .bento-hero__arrow--next {
    right: 8px;
  }
}

/* ── Reduced motion ─────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .bento-hero__grid--carousel-mobile .bento-hero__carousel-track {
    scroll-behavior: auto;
  }
}
{% endstylesheet %}

<script>
(function () {
  /* Bento hero carousel controller — runs after DOM is ready */
  function initBentoCarousels() {
    document.querySelectorAll('[data-bento-next]').forEach(function (nextBtn) {
      var sectionId = nextBtn.getAttribute('data-bento-next');
      var prevBtn   = document.querySelector('[data-bento-prev="' + sectionId + '"]');
      var track     = document.getElementById('bento-track-' + sectionId);

      if (!track || !prevBtn) return;

      /* ── Helpers ───────────────────────────────────────────── */
      function firstSlide() {
        /* First slide that is actually visible — cells hidden via
           "Show in mobile" have offsetParent === null and are skipped. */
        var slides = track.querySelectorAll(':scope > .bento-hero__cell');
        for (var i = 0; i < slides.length; i++) {
          if (slides[i].offsetParent !== null) return slides[i];
        }
        return slides[0] || null;
      }

      function slideWidth() {
        var slide = firstSlide();
        if (!slide) return 0;
        /* offsetWidth + gap (8px) */
        return slide.offsetWidth + 8;
      }

      function updateArrows() {
        prevBtn.disabled = track.scrollLeft <= 4;
        nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
      }

      /* ── Arrow click handlers ──────────────────────────────── */
      nextBtn.addEventListener('click', function () {
        track.scrollBy({ left: slideWidth(), behavior: 'smooth' });
      });

      prevBtn.addEventListener('click', function () {
        track.scrollBy({ left: -slideWidth(), behavior: 'smooth' });
      });

      /* ── Sync arrow state on scroll ───────────────────────── */
      var scrollTimer;
      track.addEventListener('scroll', function () {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(updateArrows, 80);
      }, { passive: true });

      /* ── Re-evaluate on resize (orientation change, etc.) ─── */
      window.addEventListener('resize', updateArrows);

      /* ── Initial state ─────────────────────────────────────── */
      updateArrows();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBentoCarousels);
  } else {
    initBentoCarousels();
  }
})();
</script>

