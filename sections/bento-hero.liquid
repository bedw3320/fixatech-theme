{%- liquid
  assign cell_a_image         = section.settings.cell_a_image
  assign cell_a_heading       = section.settings.cell_a_heading
  assign cell_a_text          = section.settings.cell_a_text
  assign cell_b_image         = section.settings.cell_b_image
  assign cell_c_image         = section.settings.cell_c_image
  assign cell_c_heading       = section.settings.cell_c_heading
  assign cell_c_subtext       = section.settings.cell_c_subtext
  assign cell_c_product_image = section.settings.cell_c_product_image
  assign cell_c_price         = section.settings.cell_c_price
  assign cell_d_image         = section.settings.cell_d_image
  assign cell_d_cta_text      = section.settings.cell_d_cta_text
  assign cell_d_cta_link      = section.settings.cell_d_cta_link
-%}

{% style %}
  .bento-hero--{{ section.id }} {
    {% render 'spacing-style', settings: section.settings %}
    --cell-a-bg:    {{ section.settings.cell_a_bg_color }};
    --cell-a-color: {{ section.settings.cell_a_text_color }};
    --cell-c-bg:    {{ section.settings.cell_c_bg_color }};
    --cell-c-color: {{ section.settings.cell_c_text_color }};
  }
  .bento-hero--{{ section.id }} .bento-hero__grid {
    --bento-col-c: {{ section.settings.cell_c_width_pct }}%;
    --bento-row-d: {{ section.settings.cell_d_height_pct }}%;
    {% if section.settings.section_height == 'auto' %}
      aspect-ratio: 16 / 7;
    {% elsif section.settings.section_height == 'custom' %}
      aspect-ratio: auto;
      height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      aspect-ratio: auto;
      height: 100svh;
    {% else %}
      aspect-ratio: auto;
      height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  }
{% endstyle %}

<div class="section section--{{ section.settings.section_width }} spacing-style bento-hero bento-hero--{{ section.id }}">
  <div>
    <div class="bento-hero__grid">

      {%- comment -%} ── Cell A — Text card or image ───────────────────── {%- endcomment -%}
      <div class="bento-hero__cell bento-hero__cell-a{% if cell_a_image != blank %} bento-hero__cell-a--image{% endif %}">
        {%- if cell_a_image != blank -%}
          {{
            cell_a_image
            | image_url: width: 800
            | image_tag:
              class: 'bento-hero__fill-img',
              loading: 'lazy',
              widths: '400, 800',
              sizes: '(max-width: 749px) 100vw, 33vw',
              alt: cell_a_image.alt | default: ''
          }}
        {%- else -%}
          <div class="bento-hero__cell-a-content">
            {%- if cell_a_heading != blank -%}
              <h2 class="bento-hero__cell-a-heading">{{ cell_a_heading }}</h2>
            {%- endif -%}
            {%- if cell_a_text != blank -%}
              <p class="bento-hero__cell-a-text">{{ cell_a_text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Cell B — Photo ─────────────────────────────────── {%- endcomment -%}
      <div class="bento-hero__cell bento-hero__cell-b">
        {%- if cell_b_image != blank -%}
          {{
            cell_b_image
            | image_url: width: 800
            | image_tag:
              class: 'bento-hero__fill-img',
              loading: 'lazy',
              widths: '400, 800',
              sizes: '(max-width: 749px) 100vw, 33vw',
              alt: cell_b_image.alt | default: ''
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'bento-hero__placeholder' }}
        {%- endif -%}
      </div>

      {%- comment -%} ── Cell C — Promo panel or image ───────────────────── {%- endcomment -%}
      <div class="bento-hero__cell bento-hero__cell-c{% if cell_c_image != blank %} bento-hero__cell-c--image{% endif %}">
        {%- if cell_c_image != blank -%}
          {{
            cell_c_image
            | image_url: width: 800
            | image_tag:
              class: 'bento-hero__fill-img',
              loading: 'lazy',
              widths: '400, 800',
              sizes: '(max-width: 749px) 100vw, 33vw',
              alt: cell_c_image.alt | default: ''
          }}
        {%- else -%}
          <div class="bento-hero__cell-c-text">
            {%- if cell_c_heading != blank -%}
              <h3 class="bento-hero__cell-c-heading">{{ cell_c_heading }}</h3>
            {%- endif -%}
            {%- if cell_c_subtext != blank -%}
              <p class="bento-hero__cell-c-subtext">{{ cell_c_subtext }}</p>
            {%- endif -%}
          </div>

          <div class="bento-hero__cell-c-product">
            {%- if cell_c_product_image != blank -%}
              {{
                cell_c_product_image
                | image_url: width: 600
                | image_tag:
                  class: 'bento-hero__cell-c-product-img',
                  loading: 'lazy',
                  widths: '300, 600',
                  sizes: '(max-width: 749px) 80vw, 25vw',
                  alt: cell_c_product_image.alt | default: ''
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'bento-hero__placeholder' }}
            {%- endif -%}
          </div>

          {%- if cell_c_price != blank -%}
            <div class="bento-hero__price-badge">{{ cell_c_price }}</div>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- comment -%} ── Cell D — Wide photo + CTA ───────────────────────── {%- endcomment -%}
      <div class="bento-hero__cell bento-hero__cell-d">
        {%- if cell_d_image != blank -%}
          {{
            cell_d_image
            | image_url: width: 1200
            | image_tag:
              class: 'bento-hero__fill-img',
              loading: 'lazy',
              widths: '600, 900, 1200',
              sizes: '(max-width: 749px) 100vw, 66vw',
              alt: cell_d_image.alt | default: ''
          }}
        {%- else -%}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'bento-hero__placeholder' }}
        {%- endif -%}

        <div class="bento-hero__cell-d-overlay" aria-hidden="true"></div>

        {%- if cell_d_cta_text != blank -%}
          <a
            href="{{ cell_d_cta_link | default: '#' }}"
            class="bento-hero__cta {{ section.settings.cta_style }}"
            {% if cell_d_cta_link == blank %}aria-disabled="true"{% endif %}
          >
            {{- cell_d_cta_text -}}
            <svg class="bento-hero__cta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
.bento-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr var(--bento-col-c, 35%);
  grid-template-rows: 1fr var(--bento-row-d, 50%);
  gap: 8px;
}

/* ── Shared cell styles ─────────────────────────────────────── */
.bento-hero__cell {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
}

/* Shared full-cover image (used in A, B, C image mode, D) */
.bento-hero__fill-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Cell A — Text card (default) or image ──────────────────── */
.bento-hero__cell-a {
  grid-column: 1;
  grid-row: 1;
  background-color: var(--cell-a-bg, #141414);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 30px;
}

.bento-hero__cell-a--image {
  padding: 0;
}

.bento-hero__cell-a-content {
  text-align: center;
  color: var(--cell-a-color, #fff);
}

.bento-hero__cell-a-heading {
  font-size: 32px;
  margin: 0 0 12px;
  color: var(--cell-a-color, #fff);
}

.bento-hero__cell-a-text {
  font-size: 16px;
  margin: 0;
  color: var(--cell-a-color, #fff);
}

/* ── Cell B — Photo ─────────────────────────────────────────── */
.bento-hero__cell-b {
  grid-column: 2;
  grid-row: 1;
}

/* ── Cell C — Promo panel (default) or image ────────────────── */
.bento-hero__cell-c {
  grid-column: 3;
  grid-row: 1 / span 2;
  background-color: var(--cell-c-bg, #ffc600);
  display: flex;
  flex-direction: column;
  padding: 40px 30px;
}

.bento-hero__cell-c--image {
  padding: 0;
}

.bento-hero__cell-c-text {
  color: var(--cell-c-color, #141414);
  margin-bottom: 20px;
}

.bento-hero__cell-c-heading {
  font-size: 28px;
  margin: 0 0 12px;
  color: var(--cell-c-color, #141414);
}

.bento-hero__cell-c-subtext {
  font-size: 14px;
  margin: 0;
  color: var(--cell-c-color, #141414);
}

.bento-hero__cell-c-product {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.bento-hero__cell-c-product-img {
  max-width: 100%;
  max-height: 300px;
  object-fit: contain;
  display: block;
}

.bento-hero__price-badge {
  position: absolute;
  bottom: 30px;
  right: 30px;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background-color: #141414;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: #ffc600;
}

/* ── Cell D — Wide photo + CTA ──────────────────────────────── */
.bento-hero__cell-d {
  grid-column: 1 / span 2;
  grid-row: 2;
}

.bento-hero__cell-d-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  pointer-events: none;
}

/* ── CTA button — positioning only; visual styles from theme ── */
.bento-hero__cta {
  position: absolute;
  bottom: 30px;
  left: 30px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
}

.bento-hero__cta-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

/* ── Placeholder SVGs ───────────────────────────────────────── */
.bento-hero__placeholder {
  width: 100%;
  height: 100%;
  display: block;
  fill: #343434;
}

/* ── Tablet (≤ 989px) ───────────────────────────────────────── */
@media screen and (max-width: 989px) {
  .bento-hero__grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    /* Fixatech: override {% style %} height/aspect-ratio so stacked cells aren't clipped */
    aspect-ratio: auto !important;
    height: auto !important;
  }

  /* Fixatech: Figma tablet — C (promo) on top full-width, A+B side by side, D hidden */
  .bento-hero__cell-c { grid-column: 1 / -1; grid-row: 1; min-height: 300px; }
  .bento-hero__cell-a { grid-column: 1; grid-row: 2; min-height: 150px; }
  .bento-hero__cell-b { grid-column: 2; grid-row: 2; min-height: 150px; }
  .bento-hero__cell-d { display: none; }
}

/* ── Mobile (≤ 767px) — matches Horizon bento-box breakpoint ──────── */
/* Fixatech: Figma mobile layout:
   Row 1: Cell C (promo) — full width, dominant
   Row 2: Cells A + B — side by side, short strip
   Cell D: hidden on mobile */
@media screen and (max-width: 767px) {
  .bento-hero__grid {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    height: auto !important;
    aspect-ratio: auto !important;
  }

  .bento-hero__cell-c { grid-column: 1 / -1; grid-row: 1; min-height: 272px; padding: 24px 16px; }
  .bento-hero__cell-c--image { padding: 0; }
  .bento-hero__cell-c-heading { font-size: 20px; }

  .bento-hero__cell-a { grid-column: 1; grid-row: 2; min-height: 120px; padding: 20px 16px; }
  .bento-hero__cell-a--image { padding: 0; }
  .bento-hero__cell-a-heading { font-size: 18px; }

  .bento-hero__cell-b { grid-column: 2; grid-row: 2; min-height: 120px; }

  .bento-hero__cell-d { display: none; }

  .bento-hero__price-badge {
    width: 56px;
    height: 56px;
    font-size: 13px;
    bottom: 16px;
    right: 16px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Bento hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Cell A — Text card"
    },
    {
      "type": "image_picker",
      "id": "cell_a_image",
      "label": "Image",
      "info": "If set, the image replaces the text content below."
    },
    {
      "type": "text",
      "id": "cell_a_heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "textarea",
      "id": "cell_a_text",
      "label": "Subtext"
    },
    {
      "type": "color",
      "id": "cell_a_bg_color",
      "label": "Background color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "cell_a_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Cell B — Photo"
    },
    {
      "type": "image_picker",
      "id": "cell_b_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Cell C — Promo panel"
    },
    {
      "type": "image_picker",
      "id": "cell_c_image",
      "label": "Image",
      "info": "If set, the image replaces the product content below."
    },
    {
      "type": "text",
      "id": "cell_c_heading",
      "label": "Heading",
      "default": "Promotion de la semaine"
    },
    {
      "type": "textarea",
      "id": "cell_c_subtext",
      "label": "Subtext"
    },
    {
      "type": "image_picker",
      "id": "cell_c_product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "cell_c_price",
      "label": "Price badge (e.g. $99)",
      "default": "$99"
    },
    {
      "type": "color",
      "id": "cell_c_bg_color",
      "label": "Background color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "cell_c_text_color",
      "label": "Text color",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Cell D — Wide photo + CTA"
    },
    {
      "type": "image_picker",
      "id": "cell_d_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "cell_d_cta_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cell_d_cta_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "button", "label": "Primary" },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "link", "label": "Link" }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cell_c_width_pct",
      "label": "Box C width (right column)",
      "info": "Controls the width of box C. Boxes A, B and D adjust to fill the rest.",
      "min": 15,
      "max": 55,
      "step": 5,
      "default": 35,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "cell_d_height_pct",
      "label": "Box D height (bottom row)",
      "info": "Controls the height of box D. Boxes A and B adjust to fill the rest.",
      "min": 20,
      "max": 70,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Height",
      "options": [
        { "value": "auto", "label": "Auto (proportional)" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full-screen", "label": "Full screen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom height",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "vh",
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Bento hero"
    }
  ]
}
{% endschema %}
