<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <product-tabs{% unless section.settings.hide_empty_tabs == false %} data-hide-empty{% endunless %}>
    <div
      class="fixatech-product-tabs__nav"
      role="tablist"
      aria-label="{{ 'accessibility.tabs' | t | default: 'Tabs' }}"
      ref="tablist"
      style="
        --tab-font-family: var(--font-{{ section.settings.type_preset | default: 'heading' }}--family);
        --tab-font-style: var(--font-{{ section.settings.type_preset | default: 'heading' }}--style);
        --tab-font-weight: var(--font-{{ section.settings.type_preset | default: 'heading' }}--weight);
        --tab-font-size: var(--font-{{ section.settings.type_preset | default: 'heading' }}--size);
        --tab-font-line-height: var(--font-{{ section.settings.type_preset | default: 'heading' }}--line-height);
        --tab-text-transform: var(--font-{{ section.settings.type_preset | default: 'heading' }}--case);
        {% if section.settings.type_preset == 'custom' %}
          --tab-font-family: {{ section.settings.font }};
          --tab-font-size: {{ section.settings.font_size }};
          --tab-font-line-height: var(--line-height--{{ section.settings.line_height }});
          --tab-text-transform: {{ section.settings.case }};
          --tab-font-weight: inherit;
          --tab-font-style: normal;
        {% endif %}
      "
    >
      {%- comment -%}Tab buttons are built by JS from data-tab-label on each panel{%- endcomment -%}
    </div>

    <div class="fixatech-product-tabs__panels">
      {% content_for 'blocks' %}
    </div>
  </product-tabs>
</div>

{% stylesheet %}
  product-tabs {
    display: block;
    width: 100%;
  }

  .fixatech-product-tabs__nav {
    display: flex;
    gap: var(--gap-xl, 32px);
    border-bottom: 1px solid var(--color-border, #d9d9d9);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .fixatech-product-tabs__nav::-webkit-scrollbar {
    display: none;
  }

  .fixatech-product-tabs__tab {
    appearance: none;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    font-family: var(--tab-font-family);
    font-style: var(--tab-font-style);
    font-weight: var(--tab-font-weight);
    font-size: var(--tab-font-size);
    line-height: var(--tab-font-line-height);
    text-transform: var(--tab-text-transform);
    letter-spacing: 0.02em;
    padding: var(--padding-md, 16px) 0;
    white-space: nowrap;
    color: #a6a6a6;
    transition: color 0.2s ease;
    position: relative;
    bottom: -1px;
  }

  .fixatech-product-tabs__tab[aria-selected='true'] {
    color: var(--color-foreground);
    border-bottom-color: var(--color-foreground);
  }

  .fixatech-product-tabs__tab:hover {
    color: var(--color-foreground);
  }

  .fixatech-product-tabs__tab:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: -2px;
    border-radius: 2px;
  }

  .fixatech-product-tabs__panels {
    padding-block-start: var(--padding-xl, 24px);
  }

  .fixatech-product-tabs__panel {
    min-height: 80px;
  }

  /* Hide all panels except first by default (JS takes over on load) */
  .fixatech-product-tabs__panel ~ .fixatech-product-tabs__panel {
    display: none;
  }

  .fixatech-product-tabs__panel[hidden] {
    display: none;
  }

  .fixatech-product-tabs__panel:not([hidden]) {
    display: block;
  }

  .fixatech-product-tabs__files {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm, 8px);
  }

  .fixatech-product-tabs__file-link {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-xs, 8px);
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .fixatech-product-tabs__file-link .svg-wrapper {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .fixatech-product-tabs__file-link:hover {
    text-decoration-thickness: 2px;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Product tabs",
  "tag": "section",
  "class": "fixatech-product-tabs-section",
  "blocks": [
    {
      "type": "_fixatech-tab"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "hide_empty_tabs",
      "label": "Hide empty tabs",
      "default": true,
      "info": "Automatically hide tabs when their content source is empty"
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "paragraph",
          "label": "t:options.paragraph"
        },
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "h4",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "select",
      "id": "font",
      "label": "t:settings.font",
      "options": [
        {
          "value": "var(--font-body--family)",
          "label": "t:options.body"
        },
        {
          "value": "var(--font-subheading--family)",
          "label": "t:options.subheading"
        },
        {
          "value": "var(--font-heading--family)",
          "label": "t:options.heading"
        },
        {
          "value": "var(--font-accent--family)",
          "label": "t:options.accent"
        }
      ],
      "default": "var(--font-heading--family)",
      "visible_if": "{{ section.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        },
        {
          "value": "1.25rem",
          "label": "20px"
        },
        {
          "value": "1.5rem",
          "label": "24px"
        },
        {
          "value": "2rem",
          "label": "32px"
        },
        {
          "value": "2.5rem",
          "label": "40px"
        },
        {
          "value": "3rem",
          "label": "48px"
        }
      ],
      "default": "1.125rem",
      "visible_if": "{{ section.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "t:settings.line_height",
      "options": [
        {
          "value": "tight",
          "label": "t:options.tight"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "loose",
          "label": "t:options.loose"
        }
      ],
      "default": "normal",
      "visible_if": "{{ section.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        {
          "value": "none",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "uppercase",
      "visible_if": "{{ section.settings.type_preset == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Product tabs",
      "blocks": {
        "tab_description": {
          "type": "_fixatech-tab",
          "settings": {
            "heading": "Description",
            "content_source": "product_description"
          }
        },
        "tab_specs": {
          "type": "_fixatech-tab",
          "settings": {
            "heading": "Caractéristiques",
            "content_source": "metafield",
            "metafield_key": "custom.fiche_technique"
          }
        },
        "tab_resources": {
          "type": "_fixatech-tab",
          "settings": {
            "heading": "Ressources",
            "content_source": "metafield",
            "metafield_key": "custom.product_documentation"
          }
        }
      },
      "block_order": ["tab_description", "tab_specs", "tab_resources"]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
