{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign info_heading = section.settings.info_heading
  assign info_text = section.settings.info_text
  assign success_message = section.settings.success_message
  assign form_action = section.settings.form_action
-%}

<div class="fixatech-newsletter fixatech-newsletter--{{ section.id }}">
  <div class="fixatech-newsletter__container">
    {%- comment -%} Left column: Form (60%) {%- endcomment -%}
    <div class="fixatech-newsletter__form-col">
      {%- if heading != blank -%}
        <h2 class="fixatech-newsletter__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if subheading != blank -%}
        <p class="fixatech-newsletter__subheading">{{ subheading }}</p>
      {%- endif -%}

      {%- comment -%}
        Use Shopify customer form for newsletter signup.
        Falls back to custom action URL if provided.
      {%- endcomment -%}
      {%- if form_action != blank -%}
        <form
          method="post"
          action="{{ form_action }}"
          class="fixatech-newsletter__form"
          novalidate
        >
      {%- else -%}
        {% form 'customer', class: 'fixatech-newsletter__form', id: 'fixatech-newsletter-form' %}
      {%- endif -%}

        {%- comment -%} Hidden tag for Shopify customer tagging {%- endcomment -%}
        {%- unless form_action != blank -%}
          <input type="hidden" name="customer[tags]" value="newsletter">
        {%- endunless -%}

        <div class="fixatech-newsletter__fields">
          <div class="fixatech-newsletter__row">
            {% render 'fixatech-input',
              id: 'newsletter-last-name',
              name: 'customer[last_name]',
              type: 'text',
              label: 'Nom',
              placeholder: 'Votre nom de famille',
              required: true,
              autocomplete: 'family-name'
            %}

            {% render 'fixatech-input',
              id: 'newsletter-first-name',
              name: 'customer[first_name]',
              type: 'text',
              label: 'Prénom',
              placeholder: 'Votre prénom',
              required: true,
              autocomplete: 'given-name'
            %}
          </div>

          {% render 'fixatech-input',
            id: 'newsletter-email',
            name: 'customer[email]',
            type: 'email',
            label: 'Adresse courriel',
            placeholder: 'votre@courriel.com',
            required: true,
            autocomplete: 'email'
          %}

          {% render 'fixatech-input',
            id: 'newsletter-password',
            name: 'customer[password]',
            type: 'password',
            label: 'Mot de passe',
            placeholder: 'Créez un mot de passe',
            required: true,
            autocomplete: 'new-password'
          %}

          {%- comment -%} Interests checkbox group {%- endcomment -%}
          {%- if section.blocks.size > 0 -%}
            <fieldset class="fixatech-newsletter__interests">
              <legend class="fixatech-newsletter__interests-legend">Intérêts</legend>
              <div class="fixatech-newsletter__interests-grid">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'interest' -%}
                    <label class="fixatech-newsletter__checkbox" {{ block.shopify_attributes }}>
                      <input
                        type="checkbox"
                        name="customer[note][interests][]"
                        value="{{ block.settings.value | default: block.settings.label }}"
                        class="fixatech-newsletter__checkbox-input"
                      >
                      <span class="fixatech-newsletter__checkbox-mark" aria-hidden="true"></span>
                      <span class="fixatech-newsletter__checkbox-text">{{ block.settings.label }}</span>
                    </label>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endif -%}
        </div>

        <div class="fixatech-newsletter__submit">
          {% render 'fixatech-button',
            text: 'S\'INSCRIRE',
            style: 'secondary',
            type: 'submit',
            arrow: true
          %}
        </div>

        {%- comment -%} Success / error messages {%- endcomment -%}
        {%- if form.posted_successfully? -%}
          <p class="fixatech-newsletter__message fixatech-newsletter__message--success" role="status">
            {{ success_message | default: 'Merci pour votre inscription!' }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="fixatech-newsletter__message fixatech-newsletter__message--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

      {%- if form_action != blank -%}
        </form>
      {%- else -%}
        {% endform %}
      {%- endif -%}
    </div>

    {%- comment -%} Right column: Info (40%) {%- endcomment -%}
    <div class="fixatech-newsletter__info-col">
      {%- if info_heading != blank -%}
        <h3 class="fixatech-newsletter__info-heading">{{ info_heading }}</h3>
      {%- endif -%}

      {%- if info_text != blank -%}
        <div class="fixatech-newsletter__info-text">{{ info_text }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── Fixatech Newsletter Section ──────────────────────────── */
  .fixatech-newsletter {
    position: relative;
    width: 100%;
    min-height: var(--fixatech-section-height, 982px);
    background-color: var(--fixatech-yellow, #FFC600);
    display: flex;
    align-items: center;
  }

  /* ─── Container ────────────────────────────────────────────── */
  .fixatech-newsletter__container {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: 60px;
    width: 100%;
    max-width: var(--fixatech-content-width, 1238px);
    margin: 0 auto;
    padding: 100px var(--fixatech-side-padding, 137px);
    align-items: start;
  }

  /* ─── Form Column ──────────────────────────────────────────── */
  .fixatech-newsletter__heading {
    font-family: var(--fixatech-font-heading, 'Flintstock Round', sans-serif);
    font-size: var(--fixatech-font-size-h2, 60px);
    line-height: 1.1;
    color: var(--fixatech-background-dark, #141414);
    margin: 0 0 8px;
    font-weight: normal;
    text-transform: uppercase;
  }

  .fixatech-newsletter__subheading {
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body-lg, 15px);
    font-weight: var(--fixatech-font-weight-medium, 500);
    color: var(--fixatech-background-dark, #141414);
    line-height: 1.6;
    margin: 0 0 32px;
    opacity: 0.75;
    max-width: 500px;
  }

  /* ─── Form Layout ──────────────────────────────────────────── */
  .fixatech-newsletter__form {
    width: 100%;
  }

  .fixatech-newsletter__fields {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .fixatech-newsletter__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .fixatech-newsletter__submit {
    margin-top: 28px;
  }

  /* ─── Labels on yellow bg — dark text ──────────────────────── */
  .fixatech-newsletter .fixatech-field__label {
    color: var(--fixatech-background-dark, #141414);
  }

  .fixatech-newsletter .fixatech-field__required {
    color: var(--fixatech-background-dark, #141414);
  }

  /* ─── Interests Checkboxes ─────────────────────────────────── */
  .fixatech-newsletter__interests {
    border: none;
    padding: 0;
    margin: 0;
  }

  .fixatech-newsletter__interests-legend {
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body-lg, 15px);
    font-weight: var(--fixatech-font-weight-medium, 500);
    color: var(--fixatech-background-dark, #141414);
    margin-bottom: 10px;
    padding: 0;
  }

  .fixatech-newsletter__interests-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .fixatech-newsletter__checkbox {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body, 12px);
    font-weight: var(--fixatech-font-weight-medium, 500);
    color: var(--fixatech-background-dark, #141414);
    padding: 8px 18px;
    border-radius: var(--fixatech-radius-pill, 39.5px);
    background-color: var(--fixatech-overlay-light, rgba(255, 255, 255, 0.8));
    transition: var(--fixatech-transition-fast, all 0.2s ease);
    user-select: none;
  }

  .fixatech-newsletter__checkbox:hover {
    background-color: rgba(255, 255, 255, 0.95);
  }

  .fixatech-newsletter__checkbox-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .fixatech-newsletter__checkbox-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid var(--fixatech-background-dark, #141414);
    background-color: transparent;
    flex-shrink: 0;
    transition: var(--fixatech-transition-fast, all 0.2s ease);
  }

  .fixatech-newsletter__checkbox-input:checked + .fixatech-newsletter__checkbox-mark {
    background-color: var(--fixatech-background-dark, #141414);
    border-color: var(--fixatech-background-dark, #141414);
  }

  .fixatech-newsletter__checkbox-input:checked + .fixatech-newsletter__checkbox-mark::after {
    content: '';
    display: block;
    width: 5px;
    height: 9px;
    border: solid #FFC600;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
    margin-top: -2px;
  }

  .fixatech-newsletter__checkbox-input:focus-visible + .fixatech-newsletter__checkbox-mark {
    outline: 2px solid var(--fixatech-background-dark, #141414);
    outline-offset: 2px;
  }

  /* ─── Info Column ──────────────────────────────────────────── */
  .fixatech-newsletter__info-col {
    padding-top: 20px;
  }

  .fixatech-newsletter__info-heading {
    font-family: var(--fixatech-font-heading, 'Flintstock Round', sans-serif);
    font-size: 36px;
    line-height: 1.2;
    color: var(--fixatech-background-dark, #141414);
    margin: 0 0 16px;
    font-weight: normal;
    text-transform: uppercase;
  }

  .fixatech-newsletter__info-text {
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body-lg, 15px);
    font-weight: var(--fixatech-font-weight-medium, 500);
    color: var(--fixatech-background-dark, #141414);
    line-height: 1.7;
    opacity: 0.8;
  }

  .fixatech-newsletter__info-text p {
    margin: 0 0 12px;
  }

  .fixatech-newsletter__info-text p:last-child {
    margin-bottom: 0;
  }

  /* ─── Messages ─────────────────────────────────────────────── */
  .fixatech-newsletter__message {
    margin-top: 16px;
    padding: 12px 24px;
    border-radius: var(--fixatech-radius-pill, 39.5px);
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body, 12px);
    font-weight: var(--fixatech-font-weight-medium, 500);
  }

  .fixatech-newsletter__message--success {
    background-color: var(--fixatech-background-dark, #141414);
    color: var(--fixatech-yellow, #FFC600);
  }

  .fixatech-newsletter__message--error {
    background-color: #dc2626;
    color: #fff;
  }

  /* ─── Responsive: Tablet (768px–1511px) ────────────────────── */
  @media (max-width: 1511px) {
    .fixatech-newsletter {
      min-height: 700px;
    }

    .fixatech-newsletter__container {
      padding: 80px var(--fixatech-side-padding, 48px);
      gap: 40px;
    }

    .fixatech-newsletter__heading {
      font-size: 48px;
    }

    .fixatech-newsletter__info-heading {
      font-size: 28px;
    }
  }

  /* ─── Responsive: Mobile (<768px) ──────────────────────────── */
  @media (max-width: 767px) {
    .fixatech-newsletter {
      min-height: auto;
    }

    .fixatech-newsletter__container {
      grid-template-columns: 1fr;
      padding: 60px var(--fixatech-side-padding, 24px);
      gap: 40px;
    }

    .fixatech-newsletter__heading {
      font-size: 36px;
    }

    .fixatech-newsletter__row {
      grid-template-columns: 1fr;
    }

    .fixatech-newsletter__interests-grid {
      gap: 8px;
    }

    .fixatech-newsletter__checkbox {
      min-height: 48px;
    }

    .fixatech-newsletter__info-heading {
      font-size: 24px;
    }

    .fixatech-newsletter__submit .fixatech-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* ─── Reduced Motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .fixatech-newsletter__checkbox,
    .fixatech-newsletter__checkbox-mark {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fixatech Newsletter",
  "tag": "section",
  "class": "fixatech-newsletter-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INSCRIVEZ-VOUS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Créez votre compte pour accéder à nos offres exclusives et rester informé de nos nouveautés."
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Info column heading",
      "default": "POURQUOI S'INSCRIRE?"
    },
    {
      "type": "richtext",
      "id": "info_text",
      "label": "Info column text",
      "default": "<p>Recevez des offres exclusives réservées aux membres.</p><p>Soyez les premiers informés de nos nouveaux produits et promotions.</p><p>Accédez à des prix préférentiels sur notre catalogue de plus de 4 000 produits.</p>"
    },
    {
      "type": "url",
      "id": "form_action",
      "label": "Custom form action URL",
      "info": "Leave blank to use Shopify's built-in customer signup form."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Merci pour votre inscription!"
    }
  ],
  "blocks": [
    {
      "type": "interest",
      "name": "Interest",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Quincaillerie"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Form value submitted. Leave blank to use the label."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fixatech Newsletter",
      "blocks": [
        { "type": "interest", "settings": { "label": "Quincaillerie", "value": "quincaillerie" } },
        { "type": "interest", "settings": { "label": "Outils", "value": "outils" } },
        { "type": "interest", "settings": { "label": "Fixations", "value": "fixations" } },
        { "type": "interest", "settings": { "label": "Plomberie", "value": "plomberie" } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
