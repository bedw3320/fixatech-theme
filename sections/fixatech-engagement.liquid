{%- liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign watermark_image = section.settings.watermark_image
  assign watermark_opacity = section.settings.watermark_opacity | divided_by: 100.0
-%}

{% style %}
  .fixatech-engagement--{{ section.id }} {
    --engagement-watermark-opacity: {{ watermark_opacity }};
  }
{% endstyle %}

<div class="fixatech-engagement fixatech-engagement--{{ section.id }}">
  {%- if watermark_image != blank -%}
    <div class="fixatech-engagement__watermark" aria-hidden="true">
      {{
        watermark_image
        | image_url: width: 1200
        | image_tag:
          class: 'fixatech-engagement__watermark-img',
          loading: 'lazy',
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="fixatech-engagement__container">
    {%- if heading != blank -%}
      <h2 class="fixatech-engagement__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- if description != blank -%}
      <p class="fixatech-engagement__description">{{ description }}</p>
    {%- endif -%}

    {%- if cta_text != blank and cta_url != blank -%}
      {% render 'fixatech-button',
        text: cta_text,
        url: cta_url,
        style: 'primary',
        arrow: true
      %}
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ─── Fixatech Engagement Module ───────────────────────────── */
  .fixatech-engagement {
    position: relative;
    width: 100%;
    min-height: var(--fixatech-section-height, 982px);
    background-color: var(--fixatech-background-dark, #141414);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ─── Logo Watermark ───────────────────────────────────────── */
  .fixatech-engagement__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .fixatech-engagement__watermark-img {
    width: 60%;
    max-width: 800px;
    height: auto;
    object-fit: contain;
    opacity: var(--engagement-watermark-opacity, 0.06);
    filter: grayscale(100%) brightness(2);
    user-select: none;
  }

  /* ─── Container ────────────────────────────────────────────── */
  .fixatech-engagement__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--fixatech-content-width, 1238px);
    margin: 0 auto;
    padding: 100px var(--fixatech-side-padding, 137px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  /* ─── Heading ──────────────────────────────────────────────── */
  .fixatech-engagement__heading {
    font-family: var(--fixatech-font-heading, 'Flintstock Round', sans-serif);
    font-size: var(--fixatech-font-size-h2, 60px);
    line-height: 1.1;
    color: var(--fixatech-white, #fff);
    margin: 0;
    font-weight: normal;
    text-transform: uppercase;
    max-width: 800px;
  }

  /* ─── Description ──────────────────────────────────────────── */
  .fixatech-engagement__description {
    font-family: var(--fixatech-font-body, 'Geist', sans-serif);
    font-size: var(--fixatech-font-size-body-lg, 15px);
    font-weight: var(--fixatech-font-weight-medium, 500);
    color: var(--fixatech-white, #fff);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    opacity: 0.85;
  }

  /* ─── Responsive: Tablet (768px–1511px) ────────────────────── */
  @media (max-width: 1511px) {
    .fixatech-engagement {
      min-height: 700px;
    }

    .fixatech-engagement__container {
      padding: 80px var(--fixatech-side-padding, 48px);
    }

    .fixatech-engagement__watermark-img {
      width: 70%;
    }
  }

  /* ─── Responsive: Mobile (<768px) ──────────────────────────── */
  @media (max-width: 767px) {
    .fixatech-engagement {
      min-height: 500px;
    }

    .fixatech-engagement__container {
      padding: 60px var(--fixatech-side-padding, 24px);
      gap: 20px;
    }

    .fixatech-engagement__heading {
      max-width: none;
    }

    .fixatech-engagement__description {
      max-width: none;
    }

    .fixatech-engagement__watermark-img {
      width: 90%;
      max-width: none;
    }
  }

  /* ─── Reduced Motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .fixatech-engagement__watermark-img {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fixatech Engagement",
  "tag": "section",
  "class": "fixatech-engagement-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOS ENGAGEMENTS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Chez Fixatech, nous nous engageons à offrir des produits de qualité supérieure, un service rapide et un accompagnement personnalisé pour chaque projet."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "DÉCOUVREZ NOS ENGAGEMENTS"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "watermark_image",
      "label": "Logo watermark",
      "info": "Large logo displayed as semi-transparent background. Recommended: PNG with transparency."
    },
    {
      "type": "range",
      "id": "watermark_opacity",
      "label": "Watermark opacity",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 6,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Fixatech Engagement"
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
