      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "price_badge_bg_color",
      "label": "Price badge background",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "price_badge_text_color",
      "label": "Price badge text",
      "default": "#ffc600"
