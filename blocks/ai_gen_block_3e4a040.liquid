      "label": "CTA text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "CTA background color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "cta_hover_bg_color",
      "label": "CTA hover background",
      "default": "#e9b217"
    }
  ],
  "presets": [
    {
      "name": "Bento hero"
    }
  ]
}
{% endschema %}
