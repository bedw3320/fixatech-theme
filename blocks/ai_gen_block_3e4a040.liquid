{% doc %}
  @prompt
    A Bento Hero section composed of a 2-row × 3-column CSS grid. Unequal columns: left two are
    roughly equal (1fr 1fr), right column is wider (1.3fr). Rows are equal height. Gap ~8px. All
    cells border-radius: 12px, overflow: hidden.

    grid-template-columns: 1fr 1fr 1.3fr
    grid-template-rows: 1fr 1fr
    gap: 8px

    Cell placement

    ┌──────┬────────────────────────────────────────┐
    │ Cell │               Placement                │
    ├──────┼────────────────────────────────────────┤
    │ A    │ col 1 / row 1                          │
    ├──────┼────────────────────────────────────────┤
    │ B    │ col 2 / row 1                          │
    ├──────┼────────────────────────────────────────┤
    │ C    │ col 3 / rows 1–2 (grid-row: span 2)    │
    ├──────┼────────────────────────────────────────┤
    │ D    │ cols 1–2 / row 2 (grid-column: span 2) │
    └──────┴────────────────────────────────────────┘

    Cell types

    A — Solid dark bg, vertically + horizontally centered text block. No image.

    B — Full-bleed <img> / background-image, object-fit: cover. No overlay, no text.

    C — Solid brand-color bg (yellow). Top: text block. Middle: product <img> centered.
        Bottom-right: absolutely positioned circular price badge.

    D — Full-bleed <img> / background-image, object-fit: cover. Linear gradient overlay from
        transparent → rgba(0,0,0,0.5) bottom-up. Bottom-left: absolutely positioned pill CTA
        button with icon.

    Each cell is position: relative. C and D have absolutely positioned children.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /*
   * Make the Horizon _blocks section wrapper flex item fill its container.
   * Without this, shopify-block sits at its content width instead of
   * stretching to fill the section-content-wrapper flex row.
   */
  .shopify-block:has(.ai-bento-hero-{{ ai_gen_id }}) {
    flex: 1;
    min-width: 0;
  }

  .ai-bento-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  /*
   * aspect-ratio drives proportional height growth as section widens.
   * 16/7 ≈ the original 1440×630 design intent. No fixed height needed.
   */
  .ai-bento-hero-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr 1.3fr;
    grid-template-rows: 1fr 1fr;
    gap: 8px;
    aspect-ratio: 16 / 7;
  }

  /* ── Cells (shared) ───────────────────────────────────────── */
  .ai-bento-hero-cell-{{ ai_gen_id }} {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  /* ── Cell A ───────────────────────────────────────────────── */
  .ai-bento-hero-cell-a-{{ ai_gen_id }} {
    grid-column: 1;
    grid-row: 1;
    background-color: {{ block.settings.cell_a_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 30px;
  }

  .ai-bento-hero-cell-a-content-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.cell_a_text_color }};
  }

  .ai-bento-hero-cell-a-heading-{{ ai_gen_id }} {
    font-size: 32px;
    margin: 0 0 12px;
    color: {{ block.settings.cell_a_text_color }};
  }

  .ai-bento-hero-cell-a-text-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0;
    color: {{ block.settings.cell_a_text_color }};
  }

  /* ── Cell B ───────────────────────────────────────────────── */
  .ai-bento-hero-cell-b-{{ ai_gen_id }} {
    grid-column: 2;
    grid-row: 1;
  }

  .ai-bento-hero-cell-b-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bento-hero-cell-b-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bento-hero-cell-b-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  /* ── Cell C ───────────────────────────────────────────────── */
  .ai-bento-hero-cell-c-{{ ai_gen_id }} {
    grid-column: 3;
    grid-row: span 2;
    background-color: {{ block.settings.cell_c_bg_color }};
    display: flex;
    flex-direction: column;
    padding: 40px 30px;
  }

  .ai-bento-hero-cell-c-text-{{ ai_gen_id }} {
    color: {{ block.settings.cell_c_text_color }};
    margin-bottom: 20px;
  }

  .ai-bento-hero-cell-c-heading-{{ ai_gen_id }} {
    font-size: 28px;
    margin: 0 0 12px;
    color: {{ block.settings.cell_c_text_color }};
  }

  .ai-bento-hero-cell-c-subtext-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
    color: {{ block.settings.cell_c_text_color }};
  }

  .ai-bento-hero-cell-c-product-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .ai-bento-hero-cell-c-product-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 300px;
    object-fit: contain;
  }

  .ai-bento-hero-cell-c-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bento-hero-cell-c-product-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-bento-hero-cell-c-badge-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    right: 30px;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: #141414;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: #ffc600;
  }

  /* ── Cell D ───────────────────────────────────────────────── */
  .ai-bento-hero-cell-d-{{ ai_gen_id }} {
    grid-column: span 2;
    grid-row: 2;
  }

  .ai-bento-hero-cell-d-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bento-hero-cell-d-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bento-hero-cell-d-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 200px;
  }

  .ai-bento-hero-cell-d-overlay-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
    pointer-events: none;
  }

  .ai-bento-hero-cell-d-cta-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 30px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: 100px;
    font-size: 16px;
    font-weight: 600;
    transition: filter 0.2s ease;
  }

  .ai-bento-hero-cell-d-cta-{{ ai_gen_id }}:hover {
    filter: brightness(0.85);
  }

  .ai-bento-hero-cell-d-cta-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  /* ── Tablet (≤ 989px) ─────────────────────────────────────── */
  @media screen and (max-width: 989px) {
    .ai-bento-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      aspect-ratio: auto;
    }

    .ai-bento-hero-cell-a-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 1;
      min-height: 250px;
    }

    .ai-bento-hero-cell-b-{{ ai_gen_id }} {
      grid-column: 2;
      grid-row: 1;
      min-height: 250px;
    }

    .ai-bento-hero-cell-c-{{ ai_gen_id }} {
      grid-column: 1 / -1;
      grid-row: 2;
      min-height: 400px;
    }

    .ai-bento-hero-cell-d-{{ ai_gen_id }} {
      grid-column: 1 / -1;
      grid-row: 3;
      min-height: 300px;
    }
  }

  /* ── Mobile (≤ 749px) ─────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .ai-bento-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-bento-hero-cell-a-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 1;
      padding: 30px 20px;
    }

    .ai-bento-hero-cell-b-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 2;
    }

    .ai-bento-hero-cell-c-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 3;
      padding: 30px 20px;
    }

    .ai-bento-hero-cell-d-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 4;
    }

    .ai-bento-hero-cell-a-heading-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-bento-hero-cell-c-heading-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-bento-hero-cell-c-badge-{{ ai_gen_id }} {
      width: 64px;
      height: 64px;
      font-size: 14px;
      bottom: 20px;
      right: 20px;
    }

    .ai-bento-hero-cell-d-cta-{{ ai_gen_id }} {
      bottom: 20px;
      left: 20px;
      padding: 12px 24px;
      font-size: 14px;
    }
  }
{% endstyle %}

<bento-hero-{{ ai_gen_id }} class="ai-bento-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bento-hero-grid-{{ ai_gen_id }}">
    <div class="ai-bento-hero-cell-{{ ai_gen_id }} ai-bento-hero-cell-a-{{ ai_gen_id }}">
      <div class="ai-bento-hero-cell-a-content-{{ ai_gen_id }}">
        {% if block.settings.cell_a_heading != blank %}
          <h2 class="ai-bento-hero-cell-a-heading-{{ ai_gen_id }}">{{ block.settings.cell_a_heading }}</h2>
        {% endif %}
        {% if block.settings.cell_a_text != blank %}
          <p class="ai-bento-hero-cell-a-text-{{ ai_gen_id }}">{{ block.settings.cell_a_text }}</p>
        {% endif %}
      </div>
    </div>

    <div class="ai-bento-hero-cell-{{ ai_gen_id }} ai-bento-hero-cell-b-{{ ai_gen_id }}">
      {% if block.settings.cell_b_image %}
        <img
          src="{{ block.settings.cell_b_image | image_url: width: 800 }}"
          alt="{{ block.settings.cell_b_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.cell_b_image.width }}"
          height="{{ block.settings.cell_b_image.height }}"
          class="ai-bento-hero-cell-b-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-bento-hero-cell-b-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-bento-hero-cell-{{ ai_gen_id }} ai-bento-hero-cell-c-{{ ai_gen_id }}">
      <div class="ai-bento-hero-cell-c-text-{{ ai_gen_id }}">
        {% if block.settings.cell_c_heading != blank %}
          <h3 class="ai-bento-hero-cell-c-heading-{{ ai_gen_id }}">{{ block.settings.cell_c_heading }}</h3>
        {% endif %}
        {% if block.settings.cell_c_subtext != blank %}
          <p class="ai-bento-hero-cell-c-subtext-{{ ai_gen_id }}">{{ block.settings.cell_c_subtext }}</p>
        {% endif %}
      </div>

      <div class="ai-bento-hero-cell-c-product-{{ ai_gen_id }}">
        {% if block.settings.cell_c_product_image %}
          <img
            src="{{ block.settings.cell_c_product_image | image_url: width: 600 }}"
            alt="{{ block.settings.cell_c_product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.cell_c_product_image.width }}"
            height="{{ block.settings.cell_c_product_image.height }}"
            class="ai-bento-hero-cell-c-product-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-bento-hero-cell-c-product-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if block.settings.cell_c_price != blank %}
        <div class="ai-bento-hero-cell-c-badge-{{ ai_gen_id }}">
          {{ block.settings.cell_c_price }}
        </div>
      {% endif %}
    </div>

    <div class="ai-bento-hero-cell-{{ ai_gen_id }} ai-bento-hero-cell-d-{{ ai_gen_id }}">
      {% if block.settings.cell_d_image %}
        <img
          src="{{ block.settings.cell_d_image | image_url: width: 1200 }}"
          alt="{{ block.settings.cell_d_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.cell_d_image.width }}"
          height="{{ block.settings.cell_d_image.height }}"
          class="ai-bento-hero-cell-d-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-bento-hero-cell-d-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <div class="ai-bento-hero-cell-d-overlay-{{ ai_gen_id }}"></div>

      {% if block.settings.cell_d_cta_text != blank %}
        <a
          href="{{ block.settings.cell_d_cta_link }}"
          class="ai-bento-hero-cell-d-cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cell_d_cta_text }}
          <svg
            class="ai-bento-hero-cell-d-cta-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</bento-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class BentoHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('bento-hero-{{ ai_gen_id }}', BentoHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Bento hero",
  "settings": [
    {
      "type": "header",
      "content": "Cell A — Text card"
    },
    {
      "type": "text",
      "id": "cell_a_heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "textarea",
      "id": "cell_a_text",
      "label": "Subtext"
    },
    {
      "type": "color",
      "id": "cell_a_bg_color",
      "label": "Background color",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "cell_a_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Cell B — Photo"
    },
    {
      "type": "image_picker",
      "id": "cell_b_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Cell C — Promo panel"
    },
    {
      "type": "text",
      "id": "cell_c_heading",
      "label": "Heading",
      "default": "Promotion de la semaine"
    },
    {
      "type": "textarea",
      "id": "cell_c_subtext",
      "label": "Subtext"
    },
    {
      "type": "image_picker",
      "id": "cell_c_product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "cell_c_price",
      "label": "Price badge (e.g. $99)",
      "default": "$99"
    },
    {
      "type": "color",
      "id": "cell_c_bg_color",
      "label": "Background color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "cell_c_text_color",
      "label": "Text color",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Cell D — Full-width photo + CTA"
    },
    {
      "type": "image_picker",
      "id": "cell_d_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "cell_d_cta_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cell_d_cta_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Button color",
      "default": "#ffc600"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#141414"
    }
  ],
  "presets": [
    {
      "name": "Bento hero"
    }
  ]
}
{% endschema %}
