{%- doc -%}
  Renders a CTA card that replaces a product card position in a resource list.
  Full-bleed background image with optional overlay and a centered button.

  @param {object} image - Background image (image_picker value)
  @param {string} url - Link destination
  @param {string} label - Button label text
  @param {string} [style_class] - Button style class: 'button' | 'button-secondary' | 'link' (default: 'button')
  @param {boolean} [open_in_new_tab] - Open link in new tab (default: false)
  @param {boolean} [toggle_overlay] - Show overlay (default: false)
  @param {string} [overlay_color] - Overlay color with alpha
  @param {number} [border_radius] - Card border radius in px (default: 0)
{%- enddoc -%}

<div
  class="cta-card"
  style="--border-radius: {{ border_radius | default: 0 }}px;{% if border_radius > 0 %} overflow: hidden;{% endif %}"
>
  <div class="cta-card__media">
    {% render 'background-media',
      background_media: 'image',
      background_image: image,
      background_image_position: 'cover'
    %}
  </div>

  {%- if toggle_overlay -%}
    <div
      class="overlay overlay--solid"
      style="--overlay-color: {{ overlay_color | default: 'rgb(0 0 0 / 0.25)' }};"
    ></div>
  {%- endif -%}

  <div class="cta-card__content">
    <a
      {% if url == blank %}
        role="link"
        aria-disabled="true"
      {% else %}
        href="{{ url }}"
      {% endif %}
      class="{{ style_class | default: 'button' }}"
      {%- if open_in_new_tab -%}
        target="_blank"
        rel="noopener noreferrer"
      {%- endif -%}
    >
      {{- label -}}
      {%- liquid
        assign show_arrow = false
        if style_class == 'button-secondary'
          assign show_arrow = settings.secondary_button_show_arrow
        else
          assign show_arrow = settings.primary_button_show_arrow
        endif
      -%}
      {%- if show_arrow -%}
        <span class="svg-wrapper button-arrow" aria-hidden="true">
          {{- 'icon-arrow.svg' | inline_asset_content -}}
        </span>
      {%- endif -%}
    </a>
  </div>
</div>

{% stylesheet %}
  .cta-card {
    position: relative;
    overflow: hidden;
    height: 100%;
    border-radius: var(--border-radius, 0);
  }

  .cta-card__media {
    position: absolute;
    inset: 0;
  }

  .cta-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 16px;
  }
{% endstylesheet %}
