{%- doc -%}
  Intended for use in a block similar to the button block.

  @param {string} link - link to render
  @param {object} [block] - The block

  @example
  {% render 'button', link: '/collections/all' %}
{%- enddoc -%}

{% assign block_settings = block.settings %}

<a
  {% if link == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ link }}"
  {% endif %}
  class="
    size-style
    {{ block_settings.style_class }}
    {{ block_settings.style_class }}--{{ block.id }}
  "
  style="{% render 'size-style', settings: block_settings %}"
  {%- if block_settings.open_in_new_tab -%}
    target="_blank"
    rel="noopener noreferrer"
  {%- endif -%}
  {{ block.shopify_attributes }}
>
  {{- block_settings.label -}}
  {%- liquid
    assign show_arrow = false
    if block_settings.style_class == 'button-secondary'
      assign show_arrow = settings.secondary_button_show_arrow
    else
      assign show_arrow = settings.primary_button_show_arrow
    endif
  -%}
  {%- if show_arrow -%}
    <span class="svg-wrapper button-arrow" aria-hidden="true">
      {{- 'icon-arrow.svg' | inline_asset_content -}}
    </span>
  {%- endif -%}
</a>

{% stylesheet %}
  .link {
    text-decoration: none;
    text-decoration-color: currentcolor;

    &:hover {
      color: var(--color-primary-hover);
      text-decoration-color: transparent;
    }
  }

  /* Button arrow icon — injected when theme setting is enabled */
  .button:has(.button-arrow),
  .button-secondary:has(.button-arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .button-arrow {
    display: flex;
    flex-shrink: 0;
  }

  .button-arrow svg {
    width: 20px;
    height: 20px;
  }
{% endstylesheet %}
